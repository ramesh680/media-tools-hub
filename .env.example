# Copy this file to ".env" for local development.
# On Render, set these in the dashboard (Environment tab) instead - do NOT commit real keys.

# Keep the data-heavy IMDb/calendar tools OFF for the hosted free tier.
IMDB_ENABLED=false

# API keys (optional but recommended). Leave blank to disable that enrichment.
YOUTUBE_API_KEY=
TMDB_API_KEY=
TMDB_READ_ACCESS_TOKEN=

# Full https URL of the deployed "upcoming-release-movies" service.
# Leave blank until that service is live; then paste it to show the link card.
UPCOMING_MOVIES_URL=
